# =================================
# Buku 555 Environment Configuration
# =================================

# ---- Frontend (VITE_ prefix = exposed to browser) ----

# Supabase project URL and anonymous key
# Local: http://localhost:54321 / Production: https://your-project.supabase.co
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Google OAuth — used for sign-in, Drive, Sheets, Gmail
VITE_GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
VITE_GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# App settings
VITE_APP_URL=http://localhost:5173
VITE_APP_NAME=Buku 555

# ---- Backend (Supabase Edge Function secrets) ----
# Set via: supabase secrets set KEY=value

SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
GOOGLE_CLIENT_SECRET=your-google-client-secret
OPENAI_API_KEY=sk-your-openai-api-key
RESEND_API_KEY=re_your-resend-api-key
FROM_EMAIL=noreply@buku555.com
